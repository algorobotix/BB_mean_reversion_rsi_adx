# Скопируйте этот файл в .env и заполните значения

# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID или username канала для сигнальных уведомлений
# Примеры: @my_signals_channel  или  -1001234567890
TG_CHANNEL_ID=@your_channel

# Ключи Binance Futures (нужны только для торгового режима)
# Создать на https://www.binance.com/en/my/settings/api-management
# Права: Enable Futures  (Enable Reading, Enable Futures Trading)
BINANCE_API_KEY=
BINANCE_API_SECRET=
